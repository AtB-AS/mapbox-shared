{
  "name": "@atb-as/mapbox-shared",
  "version": "1.0.0",
  "description": "Mapbox style JSON, sprite icon naming, and National Stop Registry layer definitions shared between AtB's web planner and mobile app.",
  "repository": {
    "url": "https://github.com/AtB-AS/mapbox-shared"
  },
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "private": false,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "prettier": "prettier -c src",
    "check-all": "pnpm build && pnpm lint && pnpm prettier && pnpm test",
    "prepublishOnly": "pnpm build",
    "test": "jest --passWithNoTests"
  },
  "license": "EUPL-1.2",
  "files": [
    "lib"
  ],
  "peerDependencies": {
    "@atb-as/theme": ">=15"
  },
  "devDependencies": {
    "@atb-as/theme": "^15.2.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "eslint": "9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
